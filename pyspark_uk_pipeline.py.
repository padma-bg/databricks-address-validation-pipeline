python# ============================================================================
# PROJECT: Global Address Verification & Data Quality Pipeline (UK Edition)
# LANGUAGE: PySpark (Python)
# PLATFORM: Databricks Serverless SQL Warehouse & Delta Lake
# ============================================================================

from pyspark.sql import Row
from pyspark.sql.functions import col, trim, upper, when, lit

# ============================================================================
# STEP 1: BRONZE LAYER (Raw Ingestion Landing Zone)
# ============================================================================

# 1. Generate messy, unformatted UK mock data strings
uk_data = [
    Row(user_id=201, raw_address="10 Downing St, London, sw1a2aa"),              # Lowercase postcode, missing spaces
    Row(user_id=202, raw_address="  742 Evergreen Terrace, London, United Kingdom "), # Missing postcode entirely
    Row(user_id=203, raw_address="Buckingham Palace, LONDON, SW1A 1AA"),          # Erratic capitalization
    Row(user_id=204, raw_address="Fake Street, Paris, FR, 00000"),                # Not a UK address (Wrong country)
    Row(user_id=205, raw_address="12 High St, Manchester, M1 1DE")                # Clean record
]

# 2. Convert raw python collection into a PySpark DataFrame
df_uk_raw = spark.createDataFrame(uk_data)

# 3. Commit raw dataset into Delta Lake storage tables
df_uk_raw.write.format("delta").mode("overwrite").saveAsTable("bronze_uk_addresses")


# ============================================================================
# STEP 2: SILVER LAYER (Data Quality Engineering & Routing)
# ============================================================================

# 1. Pull the data from the raw Bronze layer
df_bronze = spark.table("bronze_uk_addresses")

# 2. Trim padding spaces and normalize casing to eliminate matching variations
df_cleaned = df_bronze.withColumn("clean_address", upper(trim(col("raw_address"))))

# 3. Apply Geographic and Syntactic constraints to verify UK identity
df_verified = df_cleaned.withColumn(
    "is_uk_address",
    when(
        (col("clean_address").like("%LONDON%") | 
         col("clean_address").like("%MANCHESTER%") | 
         col("clean_address").like("%UNITED KINGDOM%")), 
        lit(True)
    ).otherwise(lit(False))
).withColumn(
    "has_postcode",
    # Evaluates strings against official UK alphanumeric postal code standards using RegEx (rlike)
    when(col("clean_address").rlike("[A-Z]{1,2}[0-9R][0-9A-Z]? ?[0-9][A-Z]{2}"), lit(True)).otherwise(lit(False))
)

# 4. Synthesize checking variables into an absolute validity flag
df_final = df_verified.withColumn(
    "is_valid",
    when((col("is_uk_address") == True) & (col("has_postcode") == True), lit(True)).otherwise(lit(False))
)

# 5. Partition and write validated records to the active production layer
df_silver_uk_valid = df_final.filter(col("is_valid") == True).select("user_id", "raw_address", "is_valid")
df_silver_uk_valid.write.format("delta").mode("overwrite").saveAsTable("silver_uk_valid_addresses")

# 6. Partition and isolate non-compliant records to the Quarantine table (Dead Letter Queue)
df_silver_uk_quarantine = df_final.filter(col("is_valid") == False).select("user_id", "raw_address", "is_valid")
df_silver_uk_quarantine.write.format("delta").mode("overwrite").saveAsTable("silver_uk_quarantined_addresses")

print("PySpark pipeline executed and tables created successfully!")
